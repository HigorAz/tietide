    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.10.1",
    "@tietide/sdk": "workspace:*",
    "@tietide/shared": "workspace:*",
    "bcrypt": "^5.1.1",
